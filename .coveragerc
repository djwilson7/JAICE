[run]
branch = True
relative_files = True
omit =
    */__pycache__/*
    */.venv/*
    */setup.py
    */test_*.py
    */__init__.py
    tests/*
    client_api/db/schema/*
    client_api/db/validate_new_supabase_schema.py
    client_api/db/apply_migration_asyncpg.py
    supabase/*
    */Dockerfile*

[report]
precision = 2
skip_empty = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
